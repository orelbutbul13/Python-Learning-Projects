import random

# Snake Eyes Simulation
# Roll two dice until both land on 1.
# Display each roll and count how many attempts
# it takes to get snake eyes (1, 1).

player1 = random.randint(1, 6)
player2 = random.randint(1, 6)
roll_count = 1

while player1 != 1 or player2 != 1:
    print(player1, player2)
    player1 = random.randint(1, 6)
    player2 = random.randint(1, 6)
    roll_count += 1

print(player1, player2)
print("YAY SNAKE EYES!!!")
print(f"It took {roll_count} rolls.")
